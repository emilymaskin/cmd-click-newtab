{
  "manifest_version": 3,
  "name": "Command My Click",
  "version": "1.0",
  "description": "Opens links in a new tab when Cmd+clicked, even if the element uses JS navigation.",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs"],
  "web_accessible_resources": [
    {
      "resources": ["interceptor.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
